# ============================================================================
# AMAZON REPLENS AUTOMATION SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_TYPE=sqlite  # Options: sqlite, postgresql
DATABASE_URL=sqlite:///./replens_automation.db
# For PostgreSQL: postgresql://user:password@localhost:5432/replens_db

# ============================================================================
# AMAZON SELLING PARTNER API (SP-API) CREDENTIALS
# ============================================================================
# Get these from https://sellingpartnerapi.amazon.com/
AMAZON_CLIENT_ID=your_client_id_here
AMAZON_CLIENT_SECRET=your_client_secret_here
AMAZON_REFRESH_TOKEN=your_refresh_token_here
AMAZON_REGION=NA  # Options: NA, EU, FE (Far East)
AMAZON_SELLER_ID=your_seller_id_here

# ============================================================================
# KEEPA API CONFIGURATION
# ============================================================================
# Subscribe at https://keepa.com/#!api
KEEPA_API_KEY=your_keepa_api_key_here
KEEPA_DOMAIN=1  # 1=US, 2=GB, 3=DE, 4=FR, 5=JP, 6=CA, 7=FR, 8=IT, 9=ES, 10=IN, 11=MX, 12=AU, 13=NL, 14=SE, 15=ZA, 16=AE, 17=SG

# ============================================================================
# OPENAI API CONFIGURATION (Optional - for NLP tasks)
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4  # Options: gpt-4, gpt-3.5-turbo

# ============================================================================
# REPRICING TOOL INTEGRATION (Optional)
# ============================================================================
# Eva.guru Integration
EVA_GURU_API_KEY=your_eva_guru_api_key_here

# BQool Integration
BQOOL_API_KEY=your_bqool_api_key_here

# ============================================================================
# NOTIFICATION CONFIGURATION
# ============================================================================
# Email Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=your_email@gmail.com

# Slack Alerts (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# SYSTEM CONFIGURATION
# ============================================================================
# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/replens_automation.log

# Profitability Thresholds
MIN_PROFIT_MARGIN=0.25  # 25% minimum margin
MIN_ROI=1.0  # 100% minimum ROI
MIN_SALES_VELOCITY=10  # Minimum units/month

# Pricing Configuration
TARGET_BUY_BOX_WIN_RATE=0.90  # Target 90% Buy Box ownership
PRICE_ADJUSTMENT_FREQUENCY=hourly  # Options: hourly, daily, weekly
PRICE_ADJUSTMENT_AMOUNT=0.01  # $0.01 undercut

# Inventory Configuration
INVENTORY_TURNOVER_TARGET=4  # 4x per month
SAFETY_STOCK_DAYS=7  # Days of safety stock to maintain
REORDER_POINT_MULTIPLIER=1.5  # Multiplier for reorder point calculation

# Forecasting Configuration
FORECAST_DAYS_AHEAD=30  # Forecast 30 days ahead
SEASONALITY_ADJUSTMENT=true
PROMOTION_IMPACT_FACTOR=1.5  # 50% sales increase during promotions

# ============================================================================
# SCHEDULER CONFIGURATION
# ============================================================================
# Run times (24-hour format)
DISCOVERY_RUN_TIME=02:00  # Run product discovery at 2 AM
REPRICING_RUN_FREQUENCY=hourly  # Reprice every hour
INVENTORY_CHECK_FREQUENCY=daily  # Check inventory daily
FORECAST_UPDATE_FREQUENCY=daily  # Update forecasts daily
DASHBOARD_REFRESH_INTERVAL=300  # Refresh dashboard every 5 minutes

# ============================================================================
# INFRASTRUCTURE CONFIGURATION
# ============================================================================
# API Rate Limiting
KEEPA_RATE_LIMIT=10  # Requests per second
AMAZON_RATE_LIMIT=5  # Requests per second

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600  # Cache time-to-live in seconds (1 hour)

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# API Request Timeout
API_TIMEOUT=30  # Seconds
API_RETRIES=3  # Number of retries for failed requests
API_BACKOFF_FACTOR=2  # Exponential backoff multiplier

# ============================================================================
# DEVELOPMENT/TESTING
# ============================================================================
DEBUG_MODE=false
TEST_MODE=false  # Set to true to use test data instead of live APIs
DRY_RUN=false  # Set to true to simulate operations without making changes
